{
  "name": "mnlrbase",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "pnpm run copy-themes && vite dev",
    "dev:server": "cd backend && go run . --dir=../db serve",
    "dev:server:snapshot": "cd backend && go run . --dir=../db migrate collections",
    "dev": "concurrently \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "copy-themes": "node ./scripts/copy-themes.js",
    "build:client": "pnpm run copy-themes && vite build",
    "build:server": "cd backend && go build -tags production -ldflags=\"-w -s\" -o ../dist/mnlrbase.exe",
    "build": "pnpm run build:client && pnpm run build:server",
    "preview": "./dist/mnlrbase serve",
    "compose": "docker compose up --build -d",
    "dev:gentypes": "pocketbase-typegen --env --out=frontend/src/types/pocketbase-types.ts",
    "gentypes": "node ./scripts/generate-types.js",
    "patchandpush": "npm version patch && git push --follow-tags",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 frontend/public/logo.webp"
  },
  "dependencies": {
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.2",
    "@vue-flow/core": "^1.43.2",
    "bootstrap": "^5.3.6",
    "bootstrap-vue-next": "^0.45.0",
    "bootswatch": "^5.3.6",
    "monaco-editor": "^0.55.0",
    "monaco-tree-editor": "^1.1.6",
    "pinia": "^3.0.2",
    "pocketbase": "^0.27.0",
    "vue": "^3.5.14",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@iconify-json/bi": "^1.2.4",
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.15.18",
    "@vite-pwa/assets-generator": "^1.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/compiler-sfc": "^3.5.14",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^9.1.2",
    "pocketbase-typegen": "^1.3.1",
    "terminate": "^2.8.0",
    "typescript": "~5.9.0",
    "unplugin-icons": "^22.1.0",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0",
    "vite-plugin-vue-devtools": "^7.7.6",
    "vue-tsc": "^2.2.10",
    "workbox-build": "^7.4.1",
    "workbox-core": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-window": "^7.4.1"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1": "1.1.16",
      "brace-expansion@2": "2.1.2",
      "dompurify": "3.4.12",
      "fast-uri": "3.1.4",
      "picomatch@4": "4.0.4",
      "sharp": "0.35.0",
      "shell-quote": "1.9.0"
    }
  },
  "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e"
}
